@model WebApplication2.Models.Post

@{
    ViewData["Title"] = Model.Title;
}

<article>
    <h1>@Model.Title</h1>
    <div>
        <strong>Автор: </strong> @Model.Author <br />
        <strong>Создан: </strong> @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm") <br/>
    </div>
    <div>
        @Model.Content
    </div>
    <div>
        <a href="@Url.Action("Edit", new {id = @Model.Id})" class="btn btn-warning me-3">Редактировать</a>
        <a href="@Url.Action("Delete", new {id = @Model.Id})" class="btn btn-danger me-3">Удалить</a>
        <a href="#" class="btn btn-secondary me-3">Назад к списку</a>
    </div>
</article>