@model IEnumerable<WebApplication2.Models.Post>

@{
    ViewData["Title"] = "Посты";
}

<h2>Все посты блога</h2>

@if (!Model.Any())
{
    <p>Пока постов нет. <a href="/Blog/AddPost">Добавить первый пост</a></p>
}
else
{
    @foreach (var post in Model)
    {
        <div style="border: 1px solid #ddd; padding: 15px; margin-bottom: 15px; border-radius: 5px;">
            <h3>@post.Title</h3>
            <p>Автор: @post.Author || Дата: @post.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>
            <div>
                @post.Content
            </div>
            <div>
                <a href="@Url.Action("Details", new {id = post.Id})" class="btn btn-secondary me-3">Читать</a>
                <a href="@Url.Action("Edit", new {id = post.Id})" class="btn btn-warning me-3">Редактировать</a>
                <a href="@Url.Action("Delete", new {id = post.Id})" class="btn btn-danger me-3">Удалить</a>
            </div>
        </div>
    }
}
    
